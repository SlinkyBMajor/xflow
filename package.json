{
	"name": "xflow",
	"version": "0.1.0",
	"description": "Agentic Kanban board with configurable lane-level workflow engines",
	"scripts": {
		"start": "vite build && electrobun dev",
		"dev": "electrobun dev --watch",
		"dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
		"hmr": "vite --port 5173",
		"build:canary": "vite build && electrobun build --env=canary",
		"db:generate": "drizzle-kit generate"
	},
	"dependencies": {
		"@dnd-kit/dom": "^0.1.21",
		"@dnd-kit/helpers": "^0.1.21",
		"@dnd-kit/react": "^0.1.21",
		"@radix-ui/react-alert-dialog": "^1.1.15",
		"@radix-ui/react-context-menu": "^2.2.16",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-dropdown-menu": "^2.1.16",
		"@radix-ui/react-label": "^2.1.8",
		"@radix-ui/react-select": "^2.2.6",
		"@radix-ui/react-slot": "^1.2.4",
		"@radix-ui/react-switch": "^1.2.6",
		"@radix-ui/react-tooltip": "^1.2.8",
		"@xyflow/react": "^12.10.1",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"drizzle-orm": "^0.39.0",
		"electrobun": "1.15.1",
		"lucide-react": "^0.577.0",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"tailwind-merge": "^3.5.0",
		"tailwindcss-animate": "^1.0.7",
		"xstate": "^5.28.0"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"@types/node": "^25.3.5",
		"@types/react": "^18.3.12",
		"@types/react-dom": "^18.3.1",
		"@vitejs/plugin-react": "^4.3.4",
		"autoprefixer": "^10.4.20",
		"concurrently": "^9.1.0",
		"drizzle-kit": "^0.30.0",
		"postcss": "^8.4.49",
		"tailwindcss": "^3.4.16",
		"typescript": "^5.7.2",
		"vite": "^6.0.3",
		"vitest": "^4.0.18"
	}
}
